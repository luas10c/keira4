{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:3000",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Keira4",
    "version": "0.0.1"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "window": {
        "all": false,
        "minimize": true,
        "close": true,
        "setDecorations": true,
        "startDragging": true
      }
    },
    "windows": [
      {
        "fileDropEnabled": true,
        "decorations": false,
        "transparent": true,
        "fullscreen": false,
        "title": "Keira4",
        "minHeight": 800,
        "minWidth": 1200,
        "center": true,
        "height": 800,
        "width": 1200
      }
    ],
    "security": {
      "csp": null
    },
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDNEE1RDAxMzEwQjVDMjcKUldRblhBc3hBVjFLdk9lMFFXWWE4MHpTbkxBNlV1V2ZnV2RldG9tbWpuVjlrTGhhNHM1QmhJdjYK"
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "category": "Games",
      "identifier": "com.keira4",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  }
}
