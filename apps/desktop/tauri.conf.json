{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Keira4",
  "mainBinaryName": "Keira4",
  "version": "0.0.1",
  "identifier": "com.keira4",
  "build": {
    "beforeDevCommand": "npm run dev -w web",
    "beforeBuildCommand": "npm run build -w web",
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:1420"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/keira-editor/keira4/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2RTAwOTQwNTk3MjYwRkMKUldUOFlISlpRQW5nMWx1YjVIVEJhS2pTRkVjOTRQOGRiWFNEbW16VTNBRXJDdzgzOUJKQzM5RDAK"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "decorations": false,
        "transparent": true,
        "fullscreen": false,
        "title": "Keira4",
        "minHeight": 600,
        "minWidth": 800,
        "center": true,
        "height": 800,
        "width": 1200
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Keira4 Inc.",
    "category": "Games",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "createUpdaterArtifacts": true,
    "license": "MIT"
  }
}
